generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用戶系統（匿名 + 可選註冊）
model User {
  id            String   @id @default(uuid())
  nickname      String
  email         String?  @unique
  passwordHash  String?
  avatar        String?
  chips         Int      @default(10000) // 遊戲幣
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  seats         Seat[]
  handActions   HandAction[]
  adviceLogs    AdviceLog[]
  roomsCreated  Room[]
}

// 房間/桌子
model Room {
  id           String      @id @default(cuid())
  name         String
  roomCode     String      @unique
  maxSeats     Int         @default(6)
  minBuyIn     Int         @default(50)  // bb單位
  maxBuyIn     Int         @default(200)
  smallBlind   Int         @default(1)
  bigBlind     Int         @default(2)
  status       RoomStatus  @default(WAITING)
  handCount    Int         @default(0)
  isPublic     Boolean     @default(true)
  
  createdById  String?
  createdBy    User?       @relation(fields: [createdById], references: [id])
  
  seats        Seat[]
  hands        Hand[]
  events       TableEvent[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Seat {
  id            String      @id @default(cuid())
  roomId        String
  room          Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seatIndex     Int         // 0-5，0是SB，1是BB，5是BTN(6max)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  stack         Int         // 當前籌碼
  status        SeatStatus  @default(EMPTY)
  
  // 當前手牌狀態（遊戲中）
  holeCards     String?     // 加密儲存，例如 "AhKh"
  isFolded      Boolean     @default(false)
  isAllIn       Boolean     @default(false)
  invested      Int         @default(0) // 當前 street 已投入
  
  // 統計數據
  handsPlayed   Int         @default(0)
  handsWon      Int         @default(0)
  totalWinLoss  Int         @default(0)
  
  @@unique([roomId, seatIndex])
  @@unique([roomId, userId])
}

// 每一手牌
model Hand {
  id              String      @id @default(cuid())
  roomId          String
  room            Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  handNumber      Int
  
  // 位置資訊
  buttonSeat      Int
  sbSeat          Int
  bbSeat          Int
  
  // 牌局狀態
  deckSeed        String      // 洗牌種子（用於驗證）
  communityCards  String?     // "AsKdQhJsTc" 格式
  
  status          HandStatus  @default(PREFLOP)
  pot             Int         @default(0)
  
  // 時間戳
  startedAt       DateTime    @default(now())
  endedAt         DateTime?
  
  actions         HandAction[]
  results         HandResult[]
  adviceLogs      AdviceLog[]
  
  @@unique([roomId, handNumber])
}

// 每個 Action 記錄（最重要）
model HandAction {
  id            String    @id @default(cuid())
  handId        String
  hand          Hand      @relation(fields: [handId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  seatIndex     Int
  
  street        Street
  actionType    ActionType
  amount        Int?      // raise/call 的金額
  seq           Int       // 順序編號
  
  // 當時情境（用於分析）
  stackBefore   Int
  potBefore     Int
  toCall        Int       // 當時需要跟注多少
  
  createdAt     DateTime  @default(now())
  
  // GTO 比對
  adviceLog     AdviceLog?
}

model HandResult {
  id          String    @id @default(cuid())
  handId      String
  hand        Hand      @relation(fields: [handId], references: [id], onDelete: Cascade)
  seatIndex   Int
  winAmount   Int
  finalHand   String?   // 攤牌時的5張牌組合
  holeCards   String?   // 這手結束後解密公開
}

// GTO 建議記錄（訓練核心）
model AdviceLog {
  id              String      @id @default(cuid())
  handId          String
  hand            Hand        @relation(fields: [handId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  spotKey         String      // 例如 "6m_100bb_BTN_vs_UTG_3bet"
  handCards       String      // "AhKh" -> normalized "AKs"
  
  // GTO 建議（JSON）
  gtoMix          Json        // {"raise": 0.4, "call": 0.6, "fold": 0.0}
  reasons         String[]    // ["IP_advantage", "nut_advantage"]
  
  // 實際執行
  actualAction    String
  deviation       Float       // 偏離程度（0=完美，1=完全錯誤）
  
  actionId        String      @unique
  action          HandAction  @relation(fields: [actionId], references: [id])
  
  createdAt       DateTime    @default(now())
}

// Preflop Chart 查詢表
model PreflopChart {
  id            String    @id @default(cuid())
  format        String    // "6max_100bb"
  spot          String    // "BTN_vs_UTG_3bet"
  hand          String    // "AJs"
  
  frequency     Json      // {"raise": 0.3, "call": 0.7}
  sizing        String?   // "3x", "all_in"
  explanation   Json      // {"tags": ["blocker", "playability"], "text": "..."}
  notes         String[]
  
  @@unique([format, spot, hand])
  @@index([format, spot])
}

// 桌子事件日誌（用於重播和審計）
model TableEvent {
  id            String    @id @default(cuid())
  roomId        String
  room          Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  handId        String?
  eventType     String    // "CREATE_ROOM", "SIT_DOWN", "ACTION", etc.
  actorUserId   String?
  payload       Json      @default("{}")
  createdAt     DateTime  @default(now())
  
  @@index([roomId, createdAt])
}

// 用戶統計數據
model UserStats {
  id                String   @id @default(cuid())
  userId            String   @unique
  
  totalHands        Int      @default(0)
  handsWon          Int      @default(0)
  totalProfitLoss   Int      @default(0)
  
  // GTO 訓練數據
  adviceReceived    Int      @default(0)
  avgDeviation      Float    @default(0) // 平均偏離程度
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum RoomStatus {
  WAITING
  PLAYING
  PAUSED
  CLOSED
}

enum SeatStatus {
  EMPTY
  OCCUPIED
  AWAY
}

enum HandStatus {
  PREFLOP
  FLOP
  TURN
  RIVER
  SHOWDOWN
  FINISHED
}

enum Street {
  PREFLOP
  FLOP
  TURN
  RIVER
  SHOWDOWN
}

enum ActionType {
  FOLD
  CHECK
  CALL
  RAISE
  ALL_IN
  SB_POST
  BB_POST
  ANTE_POST
}
