{
  "name": "@cardpilot/game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "tsc": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@cardpilot/advice-engine": "0.1.0",
    "@cardpilot/game-engine": "0.1.0",
    "@cardpilot/shared-types": "0.1.0",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tsx": "^4.19.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0"
  }
}
