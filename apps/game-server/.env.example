# Runtime
NODE_ENV=development
PORT=4000
# Primary frontend origin (merged into CORS allow-list)
FRONTEND_ORIGIN=http://127.0.0.1:5173
# Optional explicit CORS list (comma-separated). Defaults include localhost/127.0.0.1 dev ports and deploy URLs.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Server timing controls
HAND_IDLE_TIMEOUT_SECONDS=60
SHOWDOWN_DECISION_TIMEOUT_SECONDS=4
RUN_COUNT_DECISION_TIMEOUT_SECONDS=15
ROOM_EMPTY_TTL_MINUTES=10

# Supabase (set all 3 together, or leave all unset for guest/local mode)
# Optional strict mode. In production, partial Supabase config now fails fast by default.
# Set to false only if you intentionally allow fallback mode.
# SUPABASE_STRICT_ENV=true
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx

# iDrive e2 (S3-compatible) — CFR data storage
# Set these for production to load CFR data from cloud.
# Leave unset for local development (reads from data/cfr/).
# E2_ACCESS_KEY_ID=your_access_key_id
# E2_SECRET_ACCESS_KEY=your_secret_access_key
# E2_ENDPOINT=https://s3.us-east-1.idrivee2.com
# E2_BUCKET=cardpilot-cfr-data
# E2_REGION=us-east-1

# CFR Solver rate limiting (per IP, sliding window)
# CFR_RATE_LIMIT=100           # max requests per window (default: 100)
# CFR_RATE_WINDOW_MS=3600000   # window size in ms (default: 3600000 = 1 hour)
