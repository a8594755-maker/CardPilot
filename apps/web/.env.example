VITE_SERVER_URL=http://127.0.0.1:4000
# Dev-only proxy target for Vite (/socket.io and /api). Falls back to VITE_SERVER_URL when unset.
VITE_DEV_SERVER_TARGET=http://127.0.0.1:4000
# Optional explicit OAuth callback target (defaults to window.location.origin)
# Useful when local auth uses localhost vs 127.0.0.1 mismatch.
# VITE_OAUTH_REDIRECT_URL=http://127.0.0.1:5173
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
VITE_CONTACT_EMAIL=security@cardpilot.app
