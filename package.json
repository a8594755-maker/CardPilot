{
  "name": "cardpilot",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cardpilot/web",
    "env:doctor": "node scripts/env-doctor.mjs",
    "build": "npm run build --workspaces",
    "build:web": "npm run build -w @cardpilot/web",
    "build:server": "npm run build -w @cardpilot/game-server",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "ci:verify": "npm run lint && npm run typecheck && npm run test && npm run build:web && npm run build:server",
    "self-play": "npx tsx apps/bot-client/src/self-play.ts",
    "self-play:v2": "npx tsx apps/bot-client/src/self-play.ts --mode train --version v2 --target 1000000 --train-every 50000",
    "train": "npx tsx packages/fast-model/src/trainer.ts",
    "train:v2": "npx tsx packages/fast-model/src/trainer.ts --v2",
    "data:download": "bash scripts/cfr-download.sh",
    "data:download:raw": "bash scripts/cfr-download.sh --raw",
    "data:download:all": "bash scripts/cfr-download.sh --all",
    "data:upload": "bash scripts/cfr-upload.sh --all"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
