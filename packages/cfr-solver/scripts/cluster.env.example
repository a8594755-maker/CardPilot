# ============================================================
# CardPilot CFR Solver — Distributed Cluster Configuration
# ============================================================
#
# Copy this file to cluster.env and edit it.
# Edit cluster.env ONCE on all machines, then use cluster.sh.
#
# Network setup: all machines must be on the same LAN or have
# TCP connectivity on COORDINATOR_PORT.
# ============================================================

# ---- Coordinator (queue server) ----
# Set this to the LAN IP of the machine running the coordinator.
# Example: 192.168.1.100, 10.0.0.5, etc.
COORDINATOR_IP="192.168.1.100"
COORDINATOR_PORT=3500

# ---- Solver config ----
# Which config(s) to solve? Options:
#   all            — Run all 9 HU configs in priority order (recommended)
#   Comma-separated list of individual configs:
#     pipeline_srp          — HU SRP 50bb, 1 bet size/street
#     pipeline_3bet         — HU 3-bet 50bb, 1 bet size/street
#     hu_btn_bb_srp_100bb   — HU BTN vs BB SRP 100bb, 3 sizes
#     hu_btn_bb_3bp_100bb   — HU BTN vs BB 3BP 100bb, 2 sizes
#     hu_btn_bb_srp_50bb    — HU BTN vs BB SRP 50bb, 2 sizes
#     hu_btn_bb_3bp_50bb    — HU BTN vs BB 3BP 50bb, 2 sizes
#     hu_co_bb_srp_100bb    — HU CO vs BB SRP 100bb, 2 sizes
#     hu_co_bb_3bp_100bb    — HU CO vs BB 3BP 100bb, 1 size
#     hu_utg_bb_srp_100bb   — HU UTG vs BB SRP 100bb, 1 size
SOLVER_CONFIG="all"

# Iterations per flop (higher = more accurate, slower)
# Default: 200000 for pipeline/standard configs
ITERATIONS=200000

# ---- Worker settings ----
# Number of solver workers per machine (0 = auto-detect based on CPU/RAM)
NUM_WORKERS=0

# Per-worker heap size in MB (0 = auto-detect)
HEAP_MB=0

# ---- Resume ----
# Always resume from previous progress? (true/false)
# When true, already-solved flops are skipped on restart.
RESUME=true

# ---- Notion reporting (optional) ----
# Create a Notion integration at https://www.notion.so/my-integrations
# Then share a database with the integration and put its ID here.
# Reports pipeline progress every 30 minutes.
# Leave empty to disable.
NOTION_API_TOKEN=""
NOTION_DATABASE_ID=""
