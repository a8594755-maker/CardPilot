{
  "name": "@cardpilot/cfr-solver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "solve": "node --import tsx src/cli/solve.ts",
    "solve:one": "node --import tsx src/cli/solve.ts --flops 1 --iterations 50000",
    "solve:200": "node --import tsx src/cli/solve.ts --flops 200 --iterations 50000 --use-selector --parallel",
    "solve:200:serial": "node --import tsx src/cli/solve.ts --flops 200 --iterations 50000 --use-selector",
    "solve:full": "node --import tsx src/cli/solve.ts --all-flops --iterations 50000 --parallel --resume",
    "solve:standard:one": "node --import tsx src/cli/solve.ts --config standard_50bb --flops 1",
    "solve:standard": "node --import tsx src/cli/solve.ts --config standard --all-flops --parallel --resume",
    "solve:standard:50bb": "node --import tsx src/cli/solve.ts --config standard_50bb --all-flops --parallel --resume",
    "solve:standard:100bb": "node --import tsx src/cli/solve.ts --config standard_100bb --all-flops --parallel --resume",
    "benchmark": "node --import tsx src/cli/benchmark.ts",
    "pipeline:coord": "node --import tsx src/cli/pipeline.ts coordinator",
    "pipeline:worker": "node --import tsx src/cli/pipeline.ts worker",
    "pipeline:status": "node --import tsx src/cli/pipeline.ts status",
    "pipeline:srp": "node --import tsx src/cli/pipeline.ts coordinator --config pipeline_srp --resume",
    "pipeline:3bet": "node --import tsx src/cli/pipeline.ts coordinator --config pipeline_3bet --resume",
    "solve:pipeline:srp": "node --import tsx src/cli/solve.ts --config pipeline_srp --all-flops --parallel --resume",
    "cluster:coord": "bash scripts/cluster.sh coord",
    "cluster:worker": "bash scripts/cluster.sh worker",
    "cluster:status": "bash scripts/cluster.sh status",
    "cluster:dashboard": "bash scripts/cluster.sh dashboard",
    "viewer": "node --import tsx viewer/serve.ts",
    "preflop": "node --import tsx src/cli/preflop-solve.ts",
    "preflop:equity": "node --import tsx src/cli/preflop-solve.ts equity",
    "preflop:solve": "node --import tsx src/cli/preflop-solve.ts solve",
    "preflop:solve:100bb": "node --import tsx src/cli/preflop-solve.ts solve --config cash_6max_100bb",
    "preflop:solve:50bb": "node --import tsx src/cli/preflop-solve.ts solve --config cash_6max_50bb",
    "preflop:solve:ante": "node --import tsx src/cli/preflop-solve.ts solve --config cash_6max_100bb_ante",
    "preflop:export": "node --import tsx src/cli/preflop-solve.ts export --all-configs",
    "preflop:verify": "node --import tsx src/cli/preflop-solve.ts verify",
    "preflop:tree": "node --import tsx src/cli/preflop-solve.ts tree --print true",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@cardpilot/poker-evaluator": "workspace:*",
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
