# Web (apps/web)
VITE_SERVER_URL=http://127.0.0.1:4000
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
VITE_CONTACT_EMAIL=security@cardpilot.app

# Server (apps/game-server)
PORT=4000
CORS_ORIGIN=http://127.0.0.1:5173
HAND_IDLE_TIMEOUT_SECONDS=60
SHOWDOWN_DECISION_TIMEOUT_SECONDS=4
RUN_COUNT_DECISION_TIMEOUT_SECONDS=15
ROOM_EMPTY_TTL_MINUTES=10

# Supabase (set all 3 together, or leave all unset for guest/local mode)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
